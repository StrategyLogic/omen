# LLM Configuration Example
# Copy this file to .env and fill in your API keys

# OpenAI API Key (Required for GPT-based analysis)
OPENAI_API_KEY="sk-..."

# DeepSeek API Key (Optional, used as alternative provider)
DEEPSEEK_API_KEY="sk-..."

# Voyage AI API Key (Optional, legacy embedding support)
VOYAGE_API_KEY="pa-..."

# Omen Configuration
ALLOW_REANALYSIS="false"
DEBUG_LLM="false"

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://omen/specs/006-startup-case-replay/contracts/tech-space-ontology.schema.json",
  "title": "TechSpaceOntology",
  "type": "object",
  "additionalProperties": true,
  "required": ["actors", "capabilities", "axioms"],
  "properties": {
    "actors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "oneOf": [
          { "type": "string", "minLength": 1 },
          {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "actor_id": { "type": "string", "minLength": 1 },
              "id": { "type": "string", "minLength": 1 },
              "name": { "type": "string", "minLength": 1 }
            }
          }
        ]
      }
    },
    "capabilities": {
      "type": "array",
      "minItems": 1
    },
    "axioms": {
      "type": "array",
      "minItems": 1
    }
  }
}
